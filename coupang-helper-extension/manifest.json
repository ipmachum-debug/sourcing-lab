{
  "manifest_version": 3,
  "name": "Coupang Sourcing Helper",
  "version": "5.3.1",
  "description": "쿠팡 AI 소싱 코치 — AI 분석 · 소싱 점수 · 마진 추정 · 리스크 분석 · 초보 추천 · 1688 키워드 · 경쟁도 · 순위추적 · WING",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel",
    "scripting",
    "alarms",
    "notifications",
    "webRequest"
  ],
  "host_permissions": [
    "https://www.coupang.com/*",
    "https://wing.coupang.com/*",
    "https://m-wing.coupang.com/*",
    "https://lumiriz.kr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.coupang.com/np/search*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.coupang.com/vp/products/*",
        "https://www.coupang.com/vp/products/*?*"
      ],
      "js": [
        "content-detail.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://wing.coupang.com/*",
        "https://m-wing.coupang.com/*"
      ],
      "js": [
        "content-wing.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected-wing.js"
      ],
      "matches": [
        "https://wing.coupang.com/*",
        "https://m-wing.coupang.com/*"
      ]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Coupang Sourcing Helper"
  }
}