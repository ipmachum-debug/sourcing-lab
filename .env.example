# ============================================================
# .env.example — 환경변수 템플릿 (실제 값은 서버의 .env 에만!)
# ============================================================
# ⚠️ 실제 비밀값을 이 파일이나 채팅/깃/PR에 넣지 마세요. 서버의 .env(비공개)에만.
#   사용법: 서버에서 `cp .env.example .env` 후 실제 값 채우고 `pm2 restart sourcing-lab --update-env`

# ---- 필수 (기존) ----
DATABASE_URL=mysql://user:pass@host:3306/sourcing_lab
JWT_SECRET=change-me-long-random
NODE_ENV=production
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_APP_ID=sourcing-lab

# ---- POIZON Open API (Phase 2, 자동 동기화) ----
# open.poizon.com Console 에서 발급. 없으면 자동 동기화 비활성(엑셀 업로드로 동작).
POIZON_APP_KEY=your_app_key
POIZON_APP_SECRET=your_app_secret
POIZON_ACCESS_TOKEN=your_access_token
# 판매자 uid (recommend-bid/batchPrice 등 일부 API 바디에 필요, 숫자)
POIZON_UID=
# OAuth redirect_uri — 앱 콘솔 Redirect URL과 정확히 일치해야 함.
# 기본값 https://lumiriz.kr/api/poizon/callback. 콘솔이 다른 값만 허용하면 여기서 덮어쓰기.
POIZON_REDIRECT_URI=
# (선택) 기본 https://open.poizon.com
POIZON_API_BASE=https://open.poizon.com
